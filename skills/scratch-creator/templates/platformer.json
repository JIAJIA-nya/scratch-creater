{
  "_comment": "平台跳跃游戏模板：重力模拟 + 键盘控制",
  "project_structure": {
    "targets": [
      {
        "isStage": true,
        "name": "Stage",
        "variables": {
          "gravity": -2,
          "score": 0
        }
      },
      {
        "isStage": false,
        "name": "玩家",
        "variables": {
          "velocity_y": 0,
          "on_ground": 0
        },
        "scripts": [
          {
            "trigger": "event_whenflagclicked",
            "description": "游戏初始化",
            "blocks": [
              "motion_gotoxy(-150, -100)",
              "data_setvariableto(velocity_y, 0)",
              "control_forever",
              "  --- 重力模拟 ---",
              "  data_changevariableby(velocity_y, gravity)",
              "  motion_changeyby(velocity_y)",
              "  --- 落地检测 ---",
              "  control_if(sensing_touchingcolor(平台颜色))",
              "    motion_changeyby(-velocity_y)",
              "    data_setvariableto(velocity_y, 0)",
              "    data_setvariableto(on_ground, 1)",
              "  --- 键盘控制 ---",
              "  control_if(sensing_keypressed(左箭头))",
              "    motion_changexby(-5)",
              "  control_if(sensing_keypressed(右箭头))",
              "    motion_changexby(5)",
              "  control_if(operator_and(key_up, on_ground))",
              "    data_setvariableto(velocity_y, 15)",
              "    data_setvariableto(on_ground, 0)"
            ]
          }
        ]
      },
      {
        "isStage": false,
        "name": "平台",
        "description": "静态平台角色，设置为一个长方形"
      }
    ]
  },
  "description": "平台跳跃游戏：模拟重力、键盘左右移动、跳跃、碰撞检测",
  "concepts": ["重力模拟", "变量", "碰撞检测", "键盘输入", "布尔运算"],
  "difficulty": "进阶"
}
