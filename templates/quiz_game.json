{
  "_comment": "问答游戏模板：提问、判断对错、计分",
  "project_structure": {
    "targets": [
      {
        "isStage": true,
        "name": "Stage",
        "variables": {
          "score": 0,
          "question_num": 0
        }
      },
      {
        "isStage": false,
        "name": "出题角色",
        "scripts": [
          {
            "trigger": "event_whenflagclicked",
            "description": "初始化并开始提问",
            "blocks": [
              "data_setvariableto(score, 0)",
              "data_setvariableto(question_num, 1)",
              "looks_say(欢迎来到问答游戏！)",
              "control_wait(2)",
              "control_repeat(3)",
              "  sensing_askandwait(问题文本)",
              "  control_if(operator_equals(answer, 正确答案))",
              "    looks_say(回答正确！)",
              "    data_changevariableby(score, 1)",
              "  control_if_else",
              "    looks_say(再想想看~)",
              "  data_changevariableby(question_num, 1)",
              "looks_say(operator_join(你的得分是： + score))"
            ]
          }
        ]
      }
    ]
  },
  "description": "问答游戏模板：提出问题、判断回答对错、统计得分",
  "concepts": ["变量", "条件判断", "用户输入", "字符串拼接"],
  "difficulty": "入门"
}
